#!/bin/sh
# Pre-push hook: reject unsigned or unverifiable commits before GitHub does.

zero_sha="0000000000000000000000000000000000000000"
failed=0

while read local_ref local_sha remote_ref remote_sha
do
    if [ "$local_sha" = "$zero_sha" ]; then
        continue
    fi

    if [ "$remote_sha" = "$zero_sha" ]; then
        revs=$(git rev-list "$local_sha" --not --remotes)
    else
        revs=$(git rev-list "$remote_sha..$local_sha")
    fi

    for commit in $revs
    do
        if ! git verify-commit "$commit" >/dev/null 2>&1; then
            echo ""
            echo "Rejecting push: commit $commit is unsigned or cannot be verified."
            echo "Create a signed replacement commit before pushing."
            failed=1
        fi
    done
done

if [ "$failed" -ne 0 ]; then
    exit 1
fi

exit 0
